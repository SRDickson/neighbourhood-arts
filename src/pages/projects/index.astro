---
import Layout from '../../layouts/Layout.astro';

const SHEET_ID = '153Ufwyhkq5sOXFOVqFV1DRHitNtPsvJu6CiYvIRsXMk';
const SHEET_TAB = 'ProjectsMaster';
const csvUrl = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=${SHEET_TAB}`;
---

<Layout
  title="Community Arts Projects | Neighbourhood Arts Albert-Eden"
  description="A curated collection of community arts projects supported by Neighbourhood Arts in Albert-Eden, Auckland."
  keywords="community arts projects, Albert-Eden, Auckland, arts initiatives, creative projects, Neighbourhood Arts"
>
  <!-- Page Header -->
  <section class="bg-gray-900 text-white pt-40 lg:pt-48 pb-20 lg:pb-28">
    <div class="container-custom text-center">
      <h1 class="text-4xl lg:text-5xl font-bold mb-6">Projects</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Explore the creative projects we've supported across Albert-Eden.
      </p>
    </div>
  </section>

  <!-- Search Bar -->
  <section class="bg-gray-100 py-6">
    <div class="container-custom">
      <div class="max-w-xl mx-auto relative">
        <input
          id="projects-search"
          type="search"
          autocomplete="off"
          placeholder="Search projects by name…"
          class="w-full pl-12 pr-4 py-3 rounded-full border border-gray-200 bg-white text-gray-800 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary"
        />
        <svg
          class="w-5 h-5 text-gray-400 absolute left-4 top-1/2 -translate-y-1/2 pointer-events-none"
          fill="none" stroke="currentColor" viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M10.5 18a7.5 7.5 0 100-15 7.5 7.5 0 000 15z" />
        </svg>
      </div>
    </div>
  </section>

  <!-- Projects Grid -->
  <section class="py-16 lg:py-24">
    <div class="container-custom">
      <div id="projects-status" class="text-center py-16 text-gray-500">
        Loading projects…
      </div>
      <div id="projects-grid" class="hidden grid md:grid-cols-2 lg:grid-cols-3 gap-8"></div>
      <div id="projects-empty" class="hidden text-center py-16">
        <p class="text-xl text-gray-500">No projects match your search.</p>
      </div>
    </div>
  </section>

  <!-- Modal -->
  <div
    id="project-modal"
    class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/75 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
  >
    <div class="bg-white rounded-lg max-w-3xl w-full max-h-[88vh] shadow-2xl relative flex flex-col overflow-hidden">
      <div class="bg-white border-b border-gray-100 px-4 py-3 flex items-center justify-between flex-shrink-0">
        <button
          id="modal-close"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium transition-colors"
          aria-label="Back to projects"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Projects
        </button>
      </div>

      <div class="overflow-y-auto p-6 lg:p-8">
        <h2 id="modal-title" class="text-2xl lg:text-3xl font-bold text-gray-900 mb-2" style="font-family: 'Playfair Display', serif;"></h2>
        <p id="modal-year" class="text-sm font-medium text-secondary uppercase tracking-wider mb-5"></p>
        <p id="modal-description" class="text-gray-700 leading-relaxed mb-6" style="white-space: pre-line;"></p>
        <div id="modal-gallery" class="grid sm:grid-cols-2 gap-4"></div>
      </div>
    </div>
  </div>

  <script define:vars={{ csvUrl }}>
    const PLACEHOLDER = '/images/placeholder-profile.jpg';

    function convertDriveUrl(url) {
      if (!url) return '';
      const trimmed = url.trim();
      if (!trimmed) return '';
      const idMatch = trimmed.match(/[?&]id=([a-zA-Z0-9_-]+)/);
      if (idMatch) return `https://lh3.googleusercontent.com/d/${idMatch[1]}`;
      const fileMatch = trimmed.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
      if (fileMatch) return `https://lh3.googleusercontent.com/d/${fileMatch[1]}`;
      return trimmed;
    }

    function parseCSV(text) {
      const rows = [];
      let row = [];
      let cell = '';
      let inQuotes = false;
      let i = 0;
      while (i < text.length) {
        const ch = text[i];
        if (inQuotes) {
          if (ch === '"') {
            if (text[i + 1] === '"') { cell += '"'; i += 2; continue; }
            inQuotes = false; i++; continue;
          }
          cell += ch; i++;
        } else {
          if (ch === '"') { inQuotes = true; i++; continue; }
          if (ch === ',') { row.push(cell); cell = ''; i++; continue; }
          if (ch === '\r' || ch === '\n') {
            if (ch === '\r' && text[i + 1] === '\n') i++;
            row.push(cell); rows.push(row); row = []; cell = ''; i++; continue;
          }
          cell += ch; i++;
        }
      }
      if (cell !== '' || row.length > 0) { row.push(cell); rows.push(row); }
      return rows;
    }

    function rowsToObjects(rows) {
      if (!rows.length) return [];
      const headers = rows[0].map(h => h.trim());
      const objects = [];
      for (let r = 1; r < rows.length; r++) {
        const values = rows[r];
        if (values.every(v => !v || !v.trim())) continue;
        const obj = {};
        headers.forEach((h, idx) => { obj[h] = (values[idx] ?? '').trim(); });
        objects.push(obj);
      }
      return objects;
    }

    function escapeHTML(str) {
      return String(str ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function buildGallery(project) {
      return [project.Hero_Final, project.Gallery_1_Final, project.Gallery_2_Final, project.Gallery_3_Final]
        .map(convertDriveUrl)
        .filter(Boolean);
    }

    const grid = document.getElementById('projects-grid');
    const status = document.getElementById('projects-status');
    const empty = document.getElementById('projects-empty');
    const search = document.getElementById('projects-search');
    const modal = document.getElementById('project-modal');
    const modalTitle = document.getElementById('modal-title');
    const modalYear = document.getElementById('modal-year');
    const modalDesc = document.getElementById('modal-description');
    const modalGallery = document.getElementById('modal-gallery');
    const modalClose = document.getElementById('modal-close');

    if (modal && modal.parentElement !== document.body) {
      document.body.appendChild(modal);
    }

    let projects = [];

    function renderGrid(filterText) {
      const q = (filterText || '').toLowerCase().trim();
      grid.innerHTML = '';
      let visibleCount = 0;
      projects.forEach((p, index) => {
        const name = p.Project_Name || '';
        if (q && !name.toLowerCase().includes(q)) return;
        const hero = convertDriveUrl(p.Hero_Final) || PLACEHOLDER;
        const card = document.createElement('article');
        card.className = 'card group cursor-pointer';
        card.dataset.index = String(index);
        card.innerHTML = `
          <div class="card-image">
            <img src="${escapeHTML(hero)}" alt="${escapeHTML(name)}" loading="lazy" referrerpolicy="no-referrer" />
          </div>
          <div class="p-6">
            ${p.Year ? `<span class="text-xs font-medium text-secondary uppercase tracking-wider">${escapeHTML(p.Year)}</span>` : ''}
            <h3 class="text-xl font-medium mt-2 group-hover:text-primary transition-colors" style="font-family: 'Playfair Display', serif;">
              ${escapeHTML(name)}
            </h3>
          </div>
        `;
        card.addEventListener('click', () => openModal(p));
        grid.appendChild(card);
        visibleCount++;
      });
      empty.classList.toggle('hidden', visibleCount > 0);
      grid.classList.toggle('hidden', visibleCount === 0);
    }

    function openModal(project) {
      modalTitle.textContent = project.Project_Name || '';
      modalYear.textContent = project.Year || '';
      modalDesc.textContent = project.Description || '';
      const images = buildGallery(project);
      modalGallery.innerHTML = images.map((src, i) => `
        <button class="block aspect-[4/3] overflow-hidden rounded-lg cursor-pointer" data-lightbox="${escapeHTML(src)}">
          <img src="${escapeHTML(src)}" alt="${escapeHTML((project.Project_Name || 'Project') + ' image ' + (i + 1))}" class="w-full h-full object-cover hover:scale-105 transition-transform" loading="lazy" referrerpolicy="no-referrer" />
        </button>
      `).join('');
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
    });

    modalGallery.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-lightbox]');
      if (!btn) return;
      e.stopPropagation();
      const src = btn.getAttribute('data-lightbox');
      const lightbox = document.createElement('div');
      lightbox.className = 'lightbox-backdrop';
      lightbox.innerHTML = `
        <button class="absolute top-4 right-4 text-white hover:text-gray-300" aria-label="Close">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
        <img src="${src}" alt="" class="max-w-[90vw] max-h-[90vh] object-contain" referrerpolicy="no-referrer" />
      `;
      lightbox.addEventListener('click', () => lightbox.remove());
      document.body.appendChild(lightbox);
    });

    search.addEventListener('input', (e) => {
      renderGrid(e.target.value);
    });

    fetch(csvUrl)
      .then(r => {
        if (!r.ok) throw new Error('Failed to load sheet');
        return r.text();
      })
      .then(text => {
        const rows = parseCSV(text);
        projects = rowsToObjects(rows).filter(p => p.Project_Name);
        status.classList.add('hidden');
        if (!projects.length) {
          empty.classList.remove('hidden');
          empty.querySelector('p').textContent = 'No projects yet.';
          return;
        }
        renderGrid('');
      })
      .catch(err => {
        console.error(err);
        status.textContent = 'Could not load projects right now. Please try again later.';
      });
  </script>
</Layout>
