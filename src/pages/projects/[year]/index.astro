---
import Layout from '../../../layouts/Layout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allProjects = await getCollection('projects');
  const years = [...new Set(allProjects.map(p => p.data.year))];

  // Include default years even if no projects exist yet
  const defaultYears = ['24-25', '23-24', '22-23'];
  const allYears = [...new Set([...years, ...defaultYears])];

  return allYears.map(year => ({
    params: { year },
    props: {
      projects: allProjects.filter(p => p.data.year === year && !p.data.draft)
    }
  }));
}

const { year } = Astro.params;
const { projects } = Astro.props;

const projectYears = ['24-25', '23-24', '22-23'];
---

<Layout
  title={`Projects ${year} | Neighbourhood Arts Albert-Eden`}
  description={`Browse community arts projects from ${year} supported by Neighbourhood Arts in Albert-Eden, Auckland.`}
  keywords={`community arts projects ${year}, Albert-Eden, Auckland, arts initiatives, creative projects`}
>
  <!-- Page Header -->
  <section class="bg-gray-900 text-white py-20 lg:py-28">
    <div class="container-custom text-center">
      <h1 class="text-4xl lg:text-5xl font-bold mb-6">Projects {year}</h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Creative projects supported during the {year} period.
      </p>
    </div>
  </section>

  <!-- Year Navigation -->
  <nav class="bg-gray-100 py-4" aria-label="Project years">
    <div class="container-custom">
      <div class="flex flex-wrap justify-center gap-4">
        {projectYears.map((y) => (
          <a
            href={`/projects/${y}`}
            class={`px-6 py-2 rounded-full font-medium transition-colors ${
              y === year
                ? 'bg-primary text-white'
                : 'bg-white text-gray-700 hover:bg-gray-200'
            }`}
          >
            {y}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Projects Grid -->
  <section class="py-16 lg:py-24">
    <div class="container-custom">
      {projects.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {projects.map((project) => (
            <ProjectCard
              title={project.data.title}
              year={project.data.year}
              thumbnail={project.data.thumbnail}
              summary={project.data.summary}
              slug={project.id}
              tags={project.data.tags}
            />
          ))}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-xl text-gray-500">No projects yet for {year}.</p>
          <p class="text-gray-400 mt-2">Check back soon or browse another year.</p>
        </div>
      )}
    </div>
  </section>
</Layout>
